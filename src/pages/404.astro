---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 · 找不到这个页面" description="404 Not Found">
  <section class="nf">
    <p class="meta">404 — Not Found</p>
    <h1>这一页走丢了</h1>
    <p class="lead">你输入的地址在简历里没有对应的章节,可能是链接过期了。</p>
    <div class="actions">
      <a class="btn primary" href="/">回到首页</a>
      <a class="btn ghost" href="/contact/">联系我</a>
    </div>
    <pre class="ascii" aria-hidden="true">{`
   ____  ___  ___
  /    ||   ||   |
 |  /  ||   ||   |
 |  \\__||   ||   |
  \\____||   ||   |
   `}</pre>
  </section>
</Layout>

<style>
  .nf {
    padding: 6rem 0;
    text-align: left;
  }
  .meta {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.2em;
    color: var(--accent);
    margin-bottom: 1.5rem;
  }
  h1 {
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 7vw, 4.5rem);
    font-weight: 400;
    line-height: 1.05;
    margin-bottom: 1rem;
  }
  .lead {
    font-size: 1.1rem;
    color: var(--ink-soft);
    max-width: 50ch;
    margin-bottom: 2rem;
  }
  .actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 4rem;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.65rem 1.2rem;
    font-size: 0.9rem;
    border-radius: 999px;
    transition: all 0.2s;
  }
  .btn.primary { background: var(--ink); color: var(--bg); }
  .btn.primary:hover { background: var(--accent); }
  .btn.ghost { color: var(--ink); border: 1px solid var(--border-strong); }
  .btn.ghost:hover { border-color: var(--ink); }

  .ascii {
    font-family: var(--font-mono);
    color: var(--border-strong);
    font-size: 0.9rem;
    line-height: 1.1;
    user-select: none;
  }
</style>
