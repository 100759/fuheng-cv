---
import Layout from '../layouts/Layout.astro';

const sections = [
  { num: '02', label: '工作经历', desc: '作业帮 · 高顿',                  href: '/experience' },
  { num: '03', label: '教育背景', desc: '河北外国语学院 · 2024',          href: '/education' },
  { num: '04', label: '项目',     desc: '代表性案例（待补充）',           href: '/projects' },
  { num: '05', label: '技能',     desc: '专业能力与工具（待补充）',       href: '/skills' },
  { num: '06', label: '联系',     desc: '邮箱 · 电话',                    href: '/contact' },
];
---

<Layout>
  <section class="hero">
    <div class="watermark" aria-hidden="true">01</div>

    <p class="hero-meta">
      <span>石家庄 · SHIJIAZHUANG</span>
      <span class="dot">·</span>
      <span>顾问 / CONSULTANT</span>
    </p>

    <h1 class="name" data-name="付恒">
      <span class="ch ch1">付</span><span class="ch ch2">恒</span>
    </h1>

    <p class="hero-sub">Fu Heng — 教育与职业规划顾问</p>

    <div class="hero-actions">
      <a class="btn primary" href="/experience">浏览经历 →</a>
      <a class="btn ghost" href="mailto:mail@fuheng.vip">写封邮件</a>
    </div>
  </section>

  <nav class="grid" aria-label="主要章节">
    {sections.map(s => (
      <article class="card">
        <span class="num">{s.num}</span>
        <span class="label">{s.label}</span>
        <span class="desc">{s.desc}</span>
        <a class="card-link" href={s.href}>进入</a>
      </article>
    ))}
  </nav>
</Layout>

<script>
  // 让首页姓名的两个字在鼠标移动时产生轻微的"视差倾斜"
  function bindParallax() {
    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduce) return;
    const name = document.querySelector<HTMLElement>('.name[data-name]');
    if (!name) return;
    const chars = name.querySelectorAll<HTMLElement>('.ch');

    function onMove(e: MouseEvent) {
      const rect = name!.getBoundingClientRect();
      const cx = rect.left + rect.width / 2;
      const cy = rect.top + rect.height / 2;
      const dx = (e.clientX - cx) / rect.width;
      const dy = (e.clientY - cy) / rect.height;
      chars.forEach((ch, i) => {
        const k = i === 0 ? 1 : -1;
        ch.style.transform = `translate(${dx * 8 * k}px, ${dy * 6 * k}px)`;
      });
    }

    function onLeave() {
      chars.forEach(ch => (ch.style.transform = ''));
    }

    window.addEventListener('mousemove', onMove);
    window.addEventListener('mouseleave', onLeave);
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', bindParallax, { once: true });
  } else {
    bindParallax();
  }
</script>

<style>
  .hero {
    position: relative;
    padding: 5rem 0 4rem;
    border-bottom: 1px solid var(--border);
  }
  .watermark {
    position: absolute;
    right: -0.5rem;
    top: 1rem;
    font-family: var(--font-serif);
    font-size: clamp(8rem, 24vw, 18rem);
    line-height: 1;
    color: transparent;
    -webkit-text-stroke: 1px var(--border-strong);
    pointer-events: none;
    user-select: none;
    letter-spacing: -0.05em;
  }

  .hero-meta {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    color: var(--ink-muted);
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }
  .hero-meta .dot { opacity: 0.5; }

  .name {
    font-family: var(--font-serif);
    font-size: clamp(5rem, 16vw, 12rem);
    font-weight: 400;
    line-height: 0.95;
    letter-spacing: -0.03em;
    margin-bottom: 1.25rem;
    display: inline-flex;
  }
  .name .ch {
    display: inline-block;
    transition: transform 0.25s ease-out;
    will-change: transform;
  }

  .hero-sub {
    font-size: 1.05rem;
    color: var(--ink-soft);
    margin-bottom: 2rem;
  }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.65rem 1.2rem;
    font-size: 0.9rem;
    border-radius: 999px;
    transition: all 0.2s;
  }
  .btn.primary {
    background: var(--ink);
    color: var(--bg);
  }
  .btn.primary:hover {
    background: var(--accent);
  }
  .btn.ghost {
    color: var(--ink);
    border: 1px solid var(--border-strong);
  }
  .btn.ghost:hover {
    border-color: var(--ink);
  }

  /* 卡片网格 */
  .grid {
    margin-top: 3rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }
  .card {
    position: relative;
    display: grid;
    grid-template-columns: auto 1fr auto;
    grid-template-rows: auto auto;
    column-gap: 1rem;
    row-gap: 0.25rem;
    padding: 1.6rem 1.4rem;
    background: var(--bg);
    color: var(--ink);
    transition: background 0.25s ease;
    overflow: hidden;
  }
  /* D4: 更克制的 hover —— 仅左侧出现一道色线 + 极淡背景 */
  .card::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 0;
    background: var(--accent);
    transition: width 0.25s ease;
  }
  .card:hover {
    background: var(--bg-soft);
  }
  .card:hover::before {
    width: 3px;
  }

  .num {
    grid-row: 1 / 3;
    align-self: start;
    font-family: var(--font-serif);
    font-size: 1.4rem;
    color: var(--ink-muted);
    transition: color 0.25s;
  }
  .card:hover .num { color: var(--accent); }
  .label {
    font-size: 1.05rem;
    font-weight: 500;
  }
  .desc {
    grid-column: 2;
    font-size: 0.85rem;
    color: var(--ink-soft);
  }
  .card-link {
    grid-row: 1 / 3;
    align-self: center;
    color: var(--ink-muted);
    font-size: 0.85rem;
    transition: transform 0.25s, color 0.25s;
  }
  .card-link::after {
    content: ' →';
  }
  .card:hover .card-link {
    transform: translateX(6px);
    color: var(--accent);
  }

  @media (max-width: 600px) {
    .hero { padding: 3rem 0 2.5rem; }
    .watermark { top: 0.5rem; right: -1rem; }
  }
</style>
