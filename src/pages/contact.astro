---
import Layout from '../layouts/Layout.astro';
import { profile } from '../data/profile';

const items = [
  {
    label: '邮箱',
    en: 'EMAIL',
    value: profile.email,
    href: `mailto:${profile.email}`,
    copy: profile.email,
  },
  {
    label: '电话',
    en: 'PHONE',
    value: profile.phone.display,
    href: `tel:${profile.phone.compact}`,
    copy: profile.phone.compact,
  },
  {
    label: '城市',
    en: 'CITY',
    value: profile.city,
  },
];
---

<Layout title="联系方式 · 付恒" pageId="contact">
  <header class="page-head">
    <div class="page-watermark" aria-hidden="true">06</div>
    <p class="eyebrow">06 / 06 — Contact</p>
    <h1 class="page-title">联系方式</h1>
    <p class="page-lead">点击下方信息可直接拨打或写邮件,也可一键复制。</p>
  </header>

  <ul class="list">
    {items.map(it => (
      <li class="row">
        <div class="label-cell">
          <span class="label">{it.label}</span>
          <span class="en">{it.en}</span>
        </div>

        {it.href ? (
          <a class="value" href={it.href}>{it.value}</a>
        ) : (
          <span class="value static">{it.value}</span>
        )}

        {it.copy ? (
          <button class="copy" data-copy={it.copy} aria-label={`复制${it.label}`}>
            <span class="copy-text">复制</span>
          </button>
        ) : <span></span>}
      </li>
    ))}
  </ul>

  <div class="signoff">
    <p>欢迎随时联系交流 ——</p>
    <p class="sign">付恒</p>
    <a href="/resume" class="resume-link">📄 查看 / 下载简历 PDF →</a>
  </div>
</Layout>

<script>
  function bindCopy() {
    document.querySelectorAll<HTMLButtonElement>('.copy').forEach(btn => {
      if ((btn as any).__bound) return;
      (btn as any).__bound = true;
      btn.addEventListener('click', async () => {
        const text = btn.dataset.copy || '';
        const textEl = btn.querySelector('.copy-text');
        if (!textEl) return;
        const original = textEl.textContent;
        try {
          await navigator.clipboard.writeText(text);
          textEl.textContent = '已复制 ✓';
          btn.classList.add('copied');
        } catch {
          textEl.textContent = '复制失败';
        }
        setTimeout(() => {
          textEl.textContent = original;
          btn.classList.remove('copied');
        }, 1500);
      });
    });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', bindCopy, { once: true });
  } else {
    bindCopy();
  }
</script>

<style>
  .list { list-style: none; }
  .row {
    display: grid;
    grid-template-columns: 140px 1fr auto;
    align-items: center;
    gap: 1.5rem;
    padding: 1.5rem 0;
    border-top: 1px solid var(--border);
  }
  .row:last-child { border-bottom: 1px solid var(--border); }

  .label-cell {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .label {
    font-size: 0.95rem;
    color: var(--ink);
  }
  .en {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--ink-muted);
    letter-spacing: 0.2em;
  }

  .value {
    font-family: var(--font-serif);
    font-size: 1.4rem;
    color: var(--ink);
    transition: color 0.2s;
  }
  a.value:hover { color: var(--accent); }
  .value.static { color: var(--ink-soft); }

  .copy {
    background: transparent;
    border: 1px solid var(--border-strong);
    padding: 0.45rem 1rem;
    border-radius: 999px;
    font-size: 0.8rem;
    color: var(--ink-soft);
    cursor: pointer;
    font-family: inherit;
    transition: all 0.2s;
  }
  .copy:hover {
    background: var(--ink);
    color: var(--bg);
    border-color: var(--ink);
  }
  .copy.copied {
    background: var(--accent);
    color: var(--bg);
    border-color: var(--accent);
  }

  .signoff {
    margin-top: 4rem;
    color: var(--ink-soft);
  }
  .sign {
    margin-top: 0.5rem;
    font-family: var(--font-serif);
    font-size: 1.6rem;
    color: var(--ink);
    margin-bottom: 1.5rem;
  }
  .resume-link {
    display: inline-block;
    padding: 0.6rem 1.1rem;
    border: 1px solid var(--border-strong);
    border-radius: 999px;
    color: var(--ink);
    font-size: 0.9rem;
    transition: all 0.2s;
  }
  .resume-link:hover {
    background: var(--ink);
    color: var(--bg);
    border-color: var(--ink);
  }

  @media (max-width: 600px) {
    .row {
      grid-template-columns: 1fr auto;
      grid-template-rows: auto auto;
      gap: 0.75rem 1rem;
    }
    .label-cell { grid-column: 1 / -1; }
    .value { font-size: 1.2rem; }
  }
</style>
