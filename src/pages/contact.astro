---
import Layout from '../layouts/Layout.astro';
import { displayEmail, profile } from '../data/profile';

const items = [
  {
    label: '邮箱',
    en: 'EMAIL',
    value: displayEmail,
    copy: profile.email,
  },
  {
    label: '电话',
    en: 'PHONE',
    value: profile.phone.display,
    copy: profile.phone.compact,
  },
  {
    label: '城市',
    en: 'CITY',
    value: profile.city,
  },
];
---

<Layout title="联系方式 · 付恒" pageId="contact">
  <header class="page-head">
    <div class="page-watermark" aria-hidden="true">06</div>
    <p class="eyebrow">06 / 06 — Contact</p>
    <h1 class="page-title">联系方式</h1>
    <p class="page-lead">点击复制按钮即可复制联系方式。</p>
  </header>

  <ul class="list">
    {items.map(it => (
      <li class="row">
        <div class="label-cell">
          <span class="label">{it.label}</span>
          <span class="en">{it.en}</span>
        </div>

        <span class="value static">{it.value}</span>

        {it.copy ? (
          <button class="ui-button ui-button-ghost copy" data-copy={it.copy} aria-label={`复制${it.label}`}>
            <span class="copy-text">复制</span>
          </button>
        ) : <span></span>}
      </li>
    ))}
  </ul>

  <div class="signoff">
    <p>欢迎随时联系交流 ——</p>
    <p class="sign">付恒</p>
    <a href="/resume/" class="ui-button ui-button-ghost">📄 查看 / 下载简历 PDF →</a>
  </div>
</Layout>

<script>
  async function copyText(text: string) {
    try {
      await navigator.clipboard.writeText(text);
      return true;
    } catch {
      const textarea = document.createElement('textarea');
      textarea.value = text;
      textarea.setAttribute('readonly', '');
      textarea.style.position = 'fixed';
      textarea.style.left = '-9999px';
      document.body.append(textarea);
      textarea.select();
      const copied = document.execCommand('copy');
      textarea.remove();
      return copied;
    }
  }

  function bindCopy() {
    document.querySelectorAll<HTMLButtonElement>('.copy').forEach(btn => {
      if (btn.dataset.copyBound === 'true') return;
      btn.dataset.copyBound = 'true';
      btn.addEventListener('click', async () => {
        const text = btn.dataset.copy || '';
        const textEl = btn.querySelector('.copy-text');
        if (!textEl) return;
        const original = textEl.textContent;
        const ok = await copyText(text);
        textEl.textContent = ok ? '已复制 ✓' : '请手动复制';
        btn.classList.toggle('copied', ok);
        setTimeout(() => {
          textEl.textContent = original;
          btn.classList.remove('copied');
        }, 1500);
      });
    });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', bindCopy, { once: true });
  } else {
    bindCopy();
  }
</script>

<style>
  .list { list-style: none; }
  .row {
    display: grid;
    grid-template-columns: 140px 1fr auto;
    align-items: center;
    gap: 1.5rem;
    padding: 1.5rem 0;
    border-top: 1px solid var(--border);
  }
  .row:last-child { border-bottom: 1px solid var(--border); }

  .label-cell {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .label {
    font-size: 0.95rem;
    color: var(--ink);
  }
  .en {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--ink-muted);
    letter-spacing: 0.2em;
  }

  .value {
    font-family: var(--font-serif);
    font-size: 1.4rem;
    color: var(--ink);
    transition: color 0.2s;
  }
  .value.static { color: var(--ink-soft); }

  .copy {
    font-size: 0.8rem;
    color: var(--ink-soft);
  }
  .copy.copied {
    background: var(--accent);
    color: var(--bg);
    border-color: var(--accent);
  }

  .signoff {
    margin-top: 4rem;
    color: var(--ink-soft);
  }
  .sign {
    margin-top: 0.5rem;
    font-family: var(--font-serif);
    font-size: 1.6rem;
    color: var(--ink);
    margin-bottom: 1.5rem;
  }
  @media (max-width: 600px) {
    .row {
      grid-template-columns: 1fr auto;
      grid-template-rows: auto auto;
      gap: 0.75rem 1rem;
    }
    .label-cell { grid-column: 1 / -1; }
    .value { font-size: 1.2rem; }
  }
</style>
