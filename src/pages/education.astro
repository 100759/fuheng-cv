---
import Layout from '../layouts/Layout.astro';
---

<Layout title="教育背景 · 付恒" pageId="education">
  <header class="page-head">
    <div class="page-watermark" aria-hidden="true">03</div>
    <p class="eyebrow">03 / 06 — Education</p>
    <h1 class="page-title">教育背景</h1>
    <p class="page-lead">本科阶段就读于河北外国语学院。</p>
  </header>

  <article class="edu">
    <div class="year" aria-hidden="true">2024</div>
    <div class="info">
      <h2 class="school">河北外国语学院</h2>
      <p class="major">航空服务艺术与管理</p>
      <p class="meta">本科 · 2024 年毕业</p>

      <div class="badges">
        <span class="badge">服务沟通</span>
        <span class="badge">礼仪与形象</span>
        <span class="badge">航空业务</span>
      </div>
    </div>
  </article>
</Layout>

<style>
  .edu {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 2.5rem;
    padding: 3rem 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    transition: background 0.25s;
  }
  .edu:hover { background: var(--bg-soft); }

  .year {
    font-family: var(--font-serif);
    font-size: clamp(4rem, 10vw, 7rem);
    color: var(--accent);
    line-height: 0.95;
    letter-spacing: -0.02em;
  }

  .school {
    font-family: var(--font-serif);
    font-size: 1.85rem;
    font-weight: 500;
    margin-bottom: 0.4rem;
  }
  .major {
    font-size: 1.1rem;
    color: var(--ink-soft);
    margin-bottom: 0.5rem;
  }
  .meta {
    color: var(--ink-muted);
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
  }

  .badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .badge {
    padding: 0.3rem 0.85rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    font-size: 0.8rem;
    color: var(--ink-soft);
    transition: all 0.2s;
  }
  .badge:hover {
    background: var(--ink);
    color: var(--bg);
    border-color: var(--ink);
  }

  @media (max-width: 600px) {
    .edu { grid-template-columns: 1fr; gap: 1rem; padding: 2rem 0; }
  }
</style>
