---
import Header from '../components/Header.astro';
import { displayEmail, profile } from '../data/profile';
import '@fontsource-variable/inter';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  /** 当前页编号,用于结构化数据 / 当前态 */
  pageId?: string;
}

const {
  title = '付恒 · 顾问',
  description = '付恒 — 教育与职业规划顾问 · 石家庄。作业帮 LPC 顾问、高顿保研顾问。',
  pageId,
} = Astro.props;

const siteUrl = profile.siteUrl;
const canonical = new URL(Astro.url.pathname, siteUrl).toString();
const ogImage = `${siteUrl}/og.svg`;

const personJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: profile.name,
  alternateName: profile.alternateName,
  jobTitle: profile.role,
  address: {
    '@type': 'PostalAddress',
    addressLocality: profile.city,
    addressCountry: 'CN',
  },
  alumniOf: {
    '@type': 'CollegeOrUniversity',
    name: profile.school,
  },
  url: siteUrl,
};
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#FBFAF7" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#111111" media="(prefers-color-scheme: dark)" />

    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <title>{title}</title>

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="zh_CN" />
    <meta property="og:site_name" content="付恒 CV" />

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {/* JSON-LD Person */}
    <script type="application/ld+json" set:html={JSON.stringify(personJsonLd)} is:inline />

    {/* 主题初始化 — 必须在样式之前内联,避免 FOUC */}
    <script is:inline>
      (function () {
        try {
          var saved = localStorage.getItem('theme');
          var sysDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          var theme = saved || (sysDark ? 'dark' : 'light');
          document.documentElement.dataset.theme = theme;
        } catch (e) {
          document.documentElement.dataset.theme = 'light';
        }
      })();
    </script>
  </head>
  <body data-page-id={pageId}>
    <Header />
    <main id="main">
      <slot />
    </main>
    <footer>
      <span>© 付恒 · {new Date().getFullYear()}</span>
      <span>{displayEmail}</span>
    </footer>
    <style>
      footer {
        max-width: 1100px;
        width: 100%;
        margin: 0 auto;
        padding: 1.5rem 2rem 2.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 0.8rem;
        color: var(--ink-muted);
        border-top: 1px solid var(--border);
      }
      footer span {
        color: var(--ink-muted);
      }

      @media (max-width: 600px) {
        footer { padding: 1.25rem 1.25rem 2rem; font-size: 0.75rem; }
      }
    </style>
  </body>
</html>
